
generator client {
  provider = "prisma-client-js"
  moduleFormat    = "cjs"
    binaryTargets   = ["native"]
}

datasource db {
  provider = "postgresql"
}



enum Role {
  USER
  ADMIN
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)

  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
}



model Registration {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   
  phone        String?
  teudatZehut  String   
  aliyahDate   DateTime


  membershipId String   @unique
  validFrom    DateTime
  paymentMethod       String?
  validTo      DateTime
  isActive     Boolean  @default(false)


  otp             String?
  otpExpiresAt    DateTime?
  otpAttemptCount Int       @default(0)
  otpWindowStart  DateTime?

  payments Payment[]
  redeems  Redeem[]

//  mailSent     Boolean  @default(false) 

  createdAt DateTime @default(now())
}


// Category -> Partner
model Category {
  id       String    @id @default(uuid())
  name     String
  createdAt DateTime @default(now()) // Category-r jonno o add kora bhalo
  partners Partner[]
}

model Partner {
  id         String   @id @default(uuid())
  name       String
  discount   String
  categoryId String
  createdAt  DateTime @default(now()) // Ei line-ti add korun

  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  redeems    Redeem[]
}

// Redeem -> Registration + Partner
model Redeem {
  id             String   @id @default(uuid())
  registrationId String
  partnerId      String
  redeemedAt     DateTime @default(now())

  // redeemCount Int     @default(1)
  
  registration   Registration @relation(fields: [registrationId], references: [id])
  partner        Partner      @relation(fields: [partnerId], references: [id])
}



// Payment -> Registration (Stripe)
model Payment {
  id              String   @id @default(uuid())
  registrationId  String
  stripeSessionId String?  @unique  
  amount          Int
  currency        String
  status          String
  method          String?  
  cardholderName  String?
  cardNumber      String?
  expireDate      String?
  cvc             String?
  createdAt       DateTime @default(now())

  registration Registration @relation(fields: [registrationId], references: [id])
}
